---
interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
}

const defaultTitle = "Fishstick Labs - Infrastructure & DevOps Advisory";
const defaultDescription = "Infrastructure advisory for early-stage teams. Twenty years of DevOps, SRE, and platform engineering experience helping teams make the right infrastructure decisions.";
const siteUrl = "https://fishsticklabs.com";

const { title = defaultTitle, description = defaultDescription, canonicalPath = "" } = Astro.props;
const canonicalUrl = `${siteUrl}${canonicalPath}`;
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- RSS Feed -->
    <link rel="alternate" type="application/rss+xml" title="Fishstick Labs" href="/rss.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <!-- Twitter -->
    <meta property="twitter:card" content="summary" />
    <meta property="twitter:url" content={canonicalUrl} />
    <meta property="twitter:title" content={title} />
    <meta property="twitter:description" content={description} />

    <link rel="canonical" href={canonicalUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />
    <script async data-id="101416164" src="//static.getclicky.com/js"
    ></script>
    <script
      data-goatcounter="https://fishsticklabs.goatcounter.com/count"
      async
      src="//gc.zgo.at/count.js"></script>

    <!-- Structured Data -->
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "ProfessionalService",
        "name": "Fishstick Labs",
        "description": "Infrastructure and DevOps advisory services for early-stage companies",
        "url": "https://fishsticklabs.com",
        "founder": {
          "@type": "Person",
          "name": "Chris Dodds",
          "jobTitle": "Infrastructure Advisor",
          "sameAs": "https://linkedin.com/in/doddschris"
        },
        "areaServed": "Worldwide",
        "serviceType": [
          "DevOps Consulting",
          "SRE Consulting",
          "Platform Engineering",
          "Cloud Cost Optimization",
          "Infrastructure Architecture"
        ]
      }
    </script>
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  * {
    box-sizing: border-box;
  }

  body {
    background: #1a1d29;
    background-image: radial-gradient(
        circle at 20% 50%,
        rgba(139, 92, 246, 0.03) 0%,
        transparent 50%
      ),
      radial-gradient(
        circle at 80% 80%,
        rgba(236, 72, 153, 0.02) 0%,
        transparent 50%
      );
    font-family: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    color: #e8eaed;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    min-height: 100vh;
    line-height: 1.6;
  }

  #main {
    padding: 60px 20px 40px;
    margin: 0 auto;
    max-width: 700px;
    width: 100%;
  }

  .site-nav {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(26, 29, 41, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    padding: 16px 20px;
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  .nav-logo {
    font-size: 1.1em;
    font-weight: 600;
    color: #ffffff;
    text-decoration: none;
    border: none;
    padding: 0;
  }

  .nav-logo:hover {
    color: #c4b5fd;
    border: none;
  }

  .nav-links {
    display: flex;
    gap: 24px;
    align-items: center;
  }

  .nav-link {
    font-size: 0.95em;
    font-weight: 500;
    color: #9ca3af;
    text-decoration: none;
    border: none;
    padding: 0;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: #e8eaed;
    border: none;
  }

  h1 {
    font-size: 3.5em;
    font-weight: 700;
    margin: 0 0 0.5em 0;
    letter-spacing: -0.02em;
    line-height: 1.1;
    background: linear-gradient(135deg, #ffffff 0%, #c4b5fd 50%, #a78bfa 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .hero {
    padding: 70px 20px 50px;
    text-align: center;
    border-bottom: 1px solid rgba(255, 255, 255, 0.06);
    background: radial-gradient(
      ellipse at 50% 0%,
      rgba(139, 92, 246, 0.08) 0%,
      transparent 60%
    );
    margin-bottom: 0;
  }

  .hero-inner {
    max-width: 650px;
    margin: 0 auto;
  }

  .tagline {
    font-size: 1.4em;
    color: #e8eaed;
    margin: 0 0 16px 0;
    font-weight: 500;
    line-height: 1.5;
  }

  .intro {
    font-size: 1.1em;
    color: #9ca3af;
    margin: 0;
    line-height: 1.75;
  }

  .section-wide {
    max-width: 1100px;
    margin: 0 auto;
    padding: 50px 20px;
  }

  .section-wide h2 {
    text-align: center;
  }

  hr {
    border: none;
    border-top: 1px solid rgba(255, 255, 255, 0.08);
    margin: 0 0 60px 0;
  }

  section {
    width: 100%;
    margin-bottom: 0;
  }

  section h2 {
    font-size: 1.8em;
    font-weight: 600;
    margin: 0 0 24px 0;
    color: #f5f5f7;
    letter-spacing: -0.02em;
  }

  section p {
    font-size: 1.125em;
    margin: 0 0 16px 0;
    color: #d8dae5;
    line-height: 1.75;
  }

  .case-study-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .case-study {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    padding: 24px 24px;
    display: flex;
    flex-direction: column;
    transition: border-color 0.2s ease, background 0.2s ease;
  }

  .case-study:hover {
    border-color: rgba(167, 139, 250, 0.25);
    background: rgba(255, 255, 255, 0.05);
  }

  .case-tag {
    display: inline-block;
    font-size: 0.7em;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #a78bfa;
    background: rgba(139, 92, 246, 0.12);
    border: 1px solid rgba(139, 92, 246, 0.25);
    padding: 3px 10px;
    border-radius: 4px;
    margin-bottom: 12px;
    align-self: flex-start;
  }

  .case-stat {
    display: flex;
    flex-direction: row;
    align-items: baseline;
    gap: 8px;
    margin-bottom: 14px;
  }

  .stat-number {
    font-size: 2em;
    font-weight: 700;
    color: #a78bfa;
    line-height: 1;
  }

  .stat-label {
    font-size: 0.75em;
    color: #9ca3af;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .case-study h3 {
    font-size: 1.2em;
    color: #ffffff;
    margin: 0 0 4px 0;
    font-weight: 600;
  }

  .case-study .case-meta {
    font-size: 0.85em !important;
    color: #9ca3af !important;
    margin: 0 0 14px 0 !important;
  }

  .case-study p {
    font-size: 0.9em;
    margin: 0 0 10px 0;
    line-height: 1.65;
  }

  .case-study .case-outcome {
    color: #a78bfa !important;
    font-weight: 500;
    font-size: 0.9em !important;
    margin-top: auto !important;
    margin-bottom: 0 !important;
    padding-top: 14px;
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .capabilities {
    color: #a78bfa !important;
    margin-top: 28px !important;
    font-weight: 500;
    font-size: 1.05em !important;
    padding: 16px 24px;
    background: rgba(139, 92, 246, 0.08);
    border-radius: 8px;
    border: 1px solid rgba(139, 92, 246, 0.15);
  }

  .intro-text {
    font-size: 1.1em !important;
  }

  ul {
    padding-left: 0;
    list-style: none;
    color: #d1d5db;
    line-height: 1.85;
    margin: 0 0 30px 0;
  }

  ul li {
    margin-bottom: 12px;
    position: relative;
    padding-left: 24px;
  }

  ul li::before {
    content: "→";
    position: absolute;
    left: 0;
    color: #a78bfa;
  }

  /* Latest post */
  .latest-post-card {
    background: rgba(255, 255, 255, 0.03);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-radius: 10px;
    padding: 32px 36px;
    max-width: 800px;
    margin: 0 auto;
  }

  .latest-post-card img,
  .latest-post-card div[style] {
    display: none;
  }

  .all-posts-link {
    text-align: center;
    margin-top: 20px;
  }

  #latest-post a {
    display: block;
    text-decoration: none;
    border: none;
  }

  #latest-post h3 {
    color: #ffffff;
    font-size: 1.5em;
    margin: 0 0 16px 0;
    font-weight: 600;
  }

  #latest-post .post-excerpt {
    color: #d8dae5;
    font-size: 1em;
    line-height: 1.7;
    margin-bottom: 16px;
    display: -webkit-box;
    -webkit-line-clamp: 5;
    -webkit-box-orient: vertical;
    overflow: hidden;
    position: relative;
  }

  #latest-post .post-excerpt::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    height: 3em;
    background: linear-gradient(to bottom, transparent, rgba(30, 33, 46, 1));
    pointer-events: none;
  }

  #latest-post .post-excerpt p {
    color: #d8dae5;
    margin: 0 0 16px 0;
  }

  #latest-post .post-excerpt p:last-child {
    margin-bottom: 0;
  }

  #latest-post .post-excerpt a {
    color: #a78bfa;
    display: inline;
  }

  #latest-post .post-footer {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 12px;
  }

  #latest-post .post-meta {
    color: #9ca3af;
    font-size: 0.9em;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  #latest-post .post-meta .separator {
    color: #6b7280;
  }

  #latest-post .read-more {
    color: #a78bfa;
    font-size: 0.9em;
    white-space: nowrap;
  }

  /* Contact */
  .contact-section {
    border-top: 1px solid rgba(255, 255, 255, 0.06);
  }

  .contact-card {
    max-width: 500px;
    margin: 0 auto;
    text-align: center;
  }

  .contact-card p {
    font-size: 1.05em;
    margin: 0 0 8px 0;
    color: #d8dae5;
  }

  .contact-details {
    font-size: 0.95em !important;
    margin-top: 12px !important;
    margin-bottom: 0 !important;
    color: #9ca3af !important;
  }

  /* Links */
  a {
    color: #a78bfa;
    text-decoration: none;
    transition: all 0.2s ease;
    border-bottom: 1px solid rgba(167, 139, 250, 0.3);
    padding-bottom: 2px;
  }

  a:hover,
  a:focus {
    color: #c4b5fd;
    border-bottom: 1px solid #c4b5fd;
  }

  /* Footer */
  .site-footer {
    text-align: center;
    padding: 24px 20px;
    color: #6b7280;
    font-size: 0.85em;
  }

  .site-footer p {
    margin: 0;
  }

  @media (max-width: 1024px) {
    .case-study-grid {
      grid-template-columns: 1fr;
      max-width: 600px;
      margin: 0 auto;
    }
  }

  @media (max-width: 768px) {
    h1 {
      font-size: 2.5em;
    }

    .hero {
      padding: 60px 20px 50px;
    }

    .hero {
      padding: 50px 20px 50px;
    }

    .tagline {
      font-size: 1.2em;
    }

    .intro {
      font-size: 1.05em;
    }

    section h2 {
      font-size: 1.8em;
    }

    #main {
      padding: 40px 20px;
    }

    ul li {
      font-size: 0.95em;
      padding: 10px 10px 10px 28px;
    }

    .intro-text {
      font-size: 1em !important;
    }

    .case-study {
      padding: 20px 20px;
    }
  }
</style>

