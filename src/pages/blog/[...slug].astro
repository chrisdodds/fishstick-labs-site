---
import type { CollectionEntry } from "astro:content";
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts.map((post) => ({
    params: { slug: post.slug },
    props: post,
  }));
}

type Props = CollectionEntry<"blog">;

const post = Astro.props;
const { Content } = await post.render();

const siteUrl = "https://fishsticklabs.com";
const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  itemListElement: [
    { "@type": "ListItem", position: 1, name: "Home", item: `${siteUrl}/` },
    { "@type": "ListItem", position: 2, name: "Blog", item: `${siteUrl}/blog` },
    { "@type": "ListItem", position: 3, name: post.data.title, item: `${siteUrl}/blog/${post.slug}` },
  ],
};
const articleSchema = {
  "@context": "https://schema.org",
  "@type": "BlogPosting",
  headline: post.data.title,
  description: post.data.description,
  author: { "@type": "Person", name: post.data.author },
  datePublished: post.data.pubDate.toISOString(),
  dateModified: post.data.pubDate.toISOString(),
  url: `${siteUrl}/blog/${post.slug}`,
  publisher: { "@type": "Organization", name: "Fishstick Labs", url: siteUrl },
};

const formatDate = (date: Date) => {
  return new Intl.DateTimeFormat("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  }).format(date);
};
---

<Layout title={`${post.data.title} - Fishstick Labs`} description={post.data.description} canonicalPath={`/blog/${post.slug}`}>
  <nav class="site-nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">Fishstick Labs</a>
      <div class="nav-links">
        <a href="/blog" class="nav-link">Blog</a>
        <a href="/#contact" class="nav-link">Contact</a>
      </div>
    </div>
  </nav>

  <div id="main">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <a href="/blog">Blog</a>
      <span class="breadcrumb-sep">/</span>
      <span aria-current="page">{post.data.title}</span>
    </nav>
    <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(articleSchema)} />

    <article class="blog-post">
      <header class="post-header">
        <h1>{post.data.title}</h1>
        <div class="post-meta">
          <span>{post.data.author}</span>
          <span class="separator">•</span>
          <time class="post-date">{formatDate(post.data.pubDate)}</time>
        </div>
      </header>

      <div class="post-content">
        <Content />
      </div>
    </article>

    <div class="post-nav-links">
      <a href="/blog">← All posts</a>
      <a href="/">Advisory — Fishstick Labs</a>
    </div>
  </div>

  <footer class="site-footer">
    <p>
      <a href="/">Home</a>
      <span class="footer-sep">·</span>
      <a href="/blog">Blog</a>
      <span class="footer-sep">·</span>
      <a href="/#contact">Contact</a>
    </p>
    <p>&copy; {new Date().getFullYear()} Fishstick Labs</p>
  </footer>
</Layout>

<style is:global>
  .blog-post {
    max-width: 700px;
    margin: 0 auto;
  }

  .post-header {
    margin-bottom: 50px;
    text-align: left;
  }

  .post-header h1 {
    font-size: 2.5em;
    margin: 0 0 15px 0;
    line-height: 1.2;
    background: none;
    -webkit-background-clip: unset;
    -webkit-text-fill-color: #ffffff;
    background-clip: unset;
    color: #ffffff;
  }

  .post-meta {
    color: #9ca3af;
    font-size: 1em;
    display: flex;
    align-items: center;
    gap: 8px;
  }

  .post-meta .separator {
    color: #6b7280;
  }

  .post-date {
    color: #9ca3af;
    font-size: 1em;
  }

  .breadcrumb {
    font-size: 0.9em;
    color: #9ca3af;
    margin-bottom: 24px;
  }

  .breadcrumb a {
    color: #a78bfa;
    border: none;
  }

  .breadcrumb-sep {
    margin: 0 0.4em;
    color: #6b7280;
  }

  .post-nav-links {
    display: flex;
    flex-wrap: wrap;
    gap: 1em;
    margin-top: 60px;
  }

  .post-nav-links a {
    color: #a78bfa;
    border: none;
  }

  .post-content {
    color: #e8eaed;
    font-size: 1.1em;
    line-height: 1.8;
  }

  .post-content h2 {
    font-size: 1.8em;
    color: #ffffff;
    margin: 50px 0 20px 0;
    font-weight: 600;
  }

  .post-content h3 {
    font-size: 1.4em;
    color: #ffffff;
    margin: 40px 0 15px 0;
    font-weight: 600;
  }

  .post-content p {
    margin: 0 0 25px 0;
  }

  .post-content a {
    color: #60a5fa;
    border-bottom: 1px solid rgba(96, 165, 250, 0.3);
    display: inline;
    word-break: break-word;
  }

  .post-content a:hover {
    color: #93c5fd;
    border-bottom-color: #93c5fd;
  }

  .post-content ul,
  .post-content ol {
    margin: 0 0 25px 0;
    padding-left: 30px;
  }

  .post-content li {
    margin-bottom: 10px;
  }

  .post-content code {
    background: rgba(255, 255, 255, 0.05);
    padding: 3px 6px;
    border-radius: 4px;
    font-size: 0.9em;
    font-family: "Courier New", monospace;
  }

  .post-content pre {
    background: rgba(255, 255, 255, 0.05);
    padding: 20px;
    border-radius: 8px;
    overflow-x: auto;
    margin: 0 0 25px 0;
    white-space: pre-wrap;
    word-wrap: break-word;
  }

  .post-content pre code {
    background: none;
    padding: 0;
    white-space: pre-wrap;
    word-wrap: break-word;
  }

  .post-content blockquote {
    border-left: 3px solid #60a5fa;
    padding-left: 20px;
    margin: 30px 0;
    color: #d1d5db;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .post-header h1 {
      font-size: 2em;
    }

    .post-content {
      font-size: 1em;
    }
  }
</style>

