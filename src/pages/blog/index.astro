---
import Layout from "../../layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("blog");
const posts = allPosts
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const formatDate = (date: Date) =>
  new Intl.DateTimeFormat("en-US", { year: "numeric", month: "long", day: "numeric" }).format(date);
---

<Layout title="Writing - Fishstick Labs" description="Writing about DevOps, SRE, and platform engineering." canonicalPath="/blog">
  <nav class="site-nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo"><span class="dot"></span>Fishstick Labs</a>
      <div class="nav-links">
        <a href="/blog" class="nav-link" aria-current="page">Blog</a>
        <a href="/rss.xml" class="nav-link">RSS</a>
        <a href="mailto:contact@fishsticklabs.com" class="nav-link">Contact</a>
      </div>
    </div>
  </nav>

  <div class="wrap-narrow" style="padding-top: 72px; padding-bottom: 80px;">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span class="sep">/</span>
      <span aria-current="page">Writing</span>
    </nav>
    <script type="application/ld+json">
      {
        "@context": "https://schema.org",
        "@type": "BreadcrumbList",
        "itemListElement": [
          { "@type": "ListItem", "position": 1, "name": "Home", "item": "https://fishsticklabs.com/" },
          { "@type": "ListItem", "position": 2, "name": "Blog", "item": "https://fishsticklabs.com/blog" }
        ]
      }
    </script>

    <div class="kicker" style="margin-bottom: 16px;">Notes from the field</div>
    <h1 style="font-size: clamp(32px, 5vw, 48px); margin-bottom: 14px;">Writing</h1>
    <p class="lead" style="margin-bottom: 52px;">
      DevOps, SRE, and platform engineering — mostly the unglamorous decisions that quietly save money or prevent outages.
    </p>

    {
      posts.length === 0 ? (
        <p style="color: var(--muted); font-style: italic;">Nothing here yet. Check back soon.</p>
      ) : (
        <div class="post-list">
          {posts.map((post) => (
            <a href={`/blog/${post.slug}`} class="post-row">
              <div class="meta">
                <time>{formatDate(post.data.pubDate)}</time>
              </div>
              <div class="post-title">{post.data.title}</div>
              <p>{post.data.description}</p>
            </a>
          ))}
        </div>
      )
    }
  </div>

  <footer class="site-footer">
    <div class="row">
      <a href="/">Home</a><span class="sep">·</span>
      <a href="/blog">Blog</a><span class="sep">·</span>
      <a href="mailto:contact@fishsticklabs.com">Contact</a>
    </div>
    © {new Date().getFullYear()} Fishstick Labs
  </footer>
</Layout>
